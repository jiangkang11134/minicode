# SmartCode 环境变量配置示例
# 复制此文件为 .env 并填入你的 API 密钥

# ── 模型配置（三选一）──

# 方式 1：OpenAI 兼容 API（推荐）
CUSTOM_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
CUSTOM_API_KEY=your-api-key-here
CUSTOM_MODEL=deepseek-v4-flash

# 方式 2：Anthropic 直连
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# 方式 3：OpenAI 直连
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# ── 审查系统 ──
MINICODE_REVIEW_MODE=strict        # off / loose / strict
MINICODE_REVIEW_SUB_MODEL=deepseek-v4-flash  # 子 Agent 独立模型（可选）

# ── 成本控制 ──
MINICODE_API_COST_LIMIT=0.50       # 单次运行最大成本（美元）

# ── Docker 沙箱 ──
# Docker Desktop 需要启动才能使用 sandbox_test 工具
